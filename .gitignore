dist/
build/
*.whl
*.tar.gz

# ── Virtual environments ──────────────────────
venv/
.venv/
env/
.env

# ── IDE ───────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
\inspiration
# ── OS ────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ── Testing / tooling ─────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml


# ── Project runtime data ──────────────────────
# Don't commit local RouteCode session/config data
.routecodecli/sessions/
.routecodecli/memory.json

# Keep .routecodecli/skills/ — project-level skills worth committing
!.routecodecli/skills/

# ── Temporary / scratch files ─────────────────
tests/tmp/
*.log
test.txt
test_progress.txt
snake_game.html


